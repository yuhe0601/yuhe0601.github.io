---
# news.liquid (reworked)
# Goal:
# - Home page: show ONLY latest 5 news items
# - News page: show ALL news grouped by year
# - NO "View all" link anywhere
---

{% assign all_news = site.news | sort: 'date' | reverse %}
{% assign is_home = page.url == '/' or page.layout == 'home' or page.layout == 'about' %}

<div class="news-section">

  {% if is_home %}

    <h2>Latest News</h2>

    <ul class="news-list">
      {% for item in all_news limit:5 %}
        <li class="news-item">
          <span class="news-date">{{ item.date | date: "%Y-%m-%d" }}</span>
          <a href="{{ item.url | relative_url }}">{{ item.title }}</a>
        </li>
      {% endfor %}
    </ul>

  {% else %}

    <h2>News</h2>

    {% assign grouped = all_news | group_by_exp: "item", "item.date | date: '%Y'" %}

    {% for year in grouped %}
      <h3 class="news-year">{{ year.name }}</h3>
      <ul class="news-list">
        {% for item in year.items %}
          <li class="news-item">
            <span class="news-date">{{ item.date | date: "%m-%d" }}</span>
            <a href="{{ item.url | relative_url }}">{{ item.title }}</a>
          </li>
        {% endfor %}
      </ul>
    {% endfor %}

  {% endif %}

</div>

<style>
.news-section {
  margin: 20px 0;
}

.news-list {
  list-style: none;
  padding: 0;
}

.news-item {
  margin: 6px 0;
  display: flex;
  gap: 10px;
}

.news-date {
  color: #888;
  min-width: 90px;
}

.news-year {
  margin-top: 20px;
  border-bottom: 1px solid #ddd;
}
</style>
